{
  "name": "adb-auth",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "npm run build:electron && concurrently \"npm run dev:renderer\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run build:renderer && npm run build:electron && electron-builder",
    "build:renderer": "tsc -p tsconfig.app.json && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "pack": "electron-builder --dir",
    "dist": "npm run build:renderer && npm run build:electron && electron-builder"
  },
  "dependencies": {
    "@noble/curves": "^1.4.0",
    "bonjour-service": "^1.2.1",
    "electron-store": "^10.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.5.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.2",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "lucide-react": "^0.511.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.6",
    "@tailwindcss/vite": "^4.1.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.codenameakshay.adb-auth",
    "productName": "ADB Auth",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
